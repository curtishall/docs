  "keyFeatures": [
    "Create and manage Calls for Service (CFS) with full intake, location, reporting party, and incident type fields",
    "Dispatch and track units through real-time status progression (Available → Dispatched → Enroute → On Scene → Clear)",
    "Keyboard-driven command line for power-user dispatch actions (status updates, notes, unit assignment)",
    "Real-time call boards by discipline (Patrol, Fire, EMS) with drag-and-drop unit assignment",
    "RapidSOS integration for emergency caller location tracking on the map",
    "NCIC/CJIS query workspace for license plates, vehicles, persons, firearms, and wanted persons",
    "BOLO broadcasts, operational greaseboard, and wrecker rotation management",
    "Dispatcher chat, SMS messaging from calls, and notification templates",
    "Role-based access control across Organization, Agency, and User scopes",
    "Live vs. Sandbox environment pairing for training and go-live promotion",
    "Configurable report number formats, citation templates, and quick call F-key shortcuts",
    "Web Admin for agency setup, user lifecycle management, and integration configuration"
  ],
  "publicApiSurface": [
    "POST /agencies/{agencyId}/users/{userId}/settings — user agency overrides",
    "GET /agencies/{agencyId}/users/{userId}/settings — get user override settings",
    "GET /admin/organizations/{orgId}/rapidsos/credentials — list RapidSOS credentials",
    "POST /admin/organizations/{orgId}/rapidsos/credentials — save RapidSOS credentials",
    "POST /admin/organizations/{orgId}/rapidsos/test — test RapidSOS credentials",
    "GET /account/api-keys — list API keys (ExternalViewer role)",
    "/agencies/{agencyId}/settings — agency settings page",
    "/agencies/{agencyId}/command-aliases — command alias configuration",
    "/agencies/{agencyId}/call-type-shortcodes — call type shortcode configuration",
    "/rapidsos — RapidSOS management page",
    "/users — user management",
    "/settings — organization settings"
  ]
}
